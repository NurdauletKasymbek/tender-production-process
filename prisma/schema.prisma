// Tender Production MVP — деректер моделі
// Барлық 8 рөл, толық цикл: Goszakup → Тексеру → Растау → Өндіріс → Қаптау → Тиеу → Логистика → Жеткізу → Жабу

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== РӨЛДЕР ==============
enum UserRole {
  ADMIN              // Әкімші
  TENDER_DEPARTMENT  // Тендерлік бөлім
  DIRECTOR           // Басшы
  PRODUCTION_HEAD    // Өндіріс бастығы
  WORKSHOP_WORKER    // Цех маманы
  PACKAGING          // Қаптау
  LOADING            // Тиеу
  LOGISTICS          // Логист
}

// ============== ТАПСЫРЫС СТАТУСТАРЫ ==============
enum OrderStatus {
  NEW_TENDER     // Жаңа тендер
  REVIEW         // Тексеру (тендерлік бөлім)
  CONFIRMATION   // Растау (басшы)
  PRODUCTION     // Өндіріс
  PACKAGING      // Қаптау
  STORAGE        // Қойма (қаптаудан кейін немесе STOCK тапсырыстарының бастапқы орны)
  LOADING        // Тиеу
  LOGISTICS      // Логистика (жолда)
  DELIVERY       // Жеткізу
  CLOSED         // Жабылған
  REJECTED       // Қабылданбаған
}

// ============== ТАПСЫРМА СТАТУСТАРЫ (өндіріс ішінде) ==============
enum TaskStatus {
  PENDING      // Күтуде
  IN_PROGRESS  // Орындалуда
  COMPLETED    // Аяқталды
  BLOCKED      // Кедергі бар
}

// ============== ОРЫНДАУ ТҮРІ (склад / өндіріс) ==============
// Тапсырыс директордың растауында осы өріс белгіленеді:
//   PRODUCTION — цехта жасалады (CONFIRMATION → PRODUCTION → PACKAGING → STORAGE → LOADING ...)
//   STOCK      — дайын өнім, цехсыз (CONFIRMATION → STORAGE → LOADING ...)
enum FulfillmentType {
  PRODUCTION
  STOCK
}

// ============== ҚОЛДАНУШЫ ==============
model User {
  id              String   @id @default(uuid())
  // Telegram байланысы — хабарлама жіберу үшін (бот: @GOSCONTROL_bot).
  // telegramId міндетті емес — username/password арқылы кіретін, ботсыз қызметкерлер де болуы мүмкін.
  telegramId      BigInt?  @unique
  telegramUsername String?
  // Username/password арқылы кіру (Web UI).
  username        String?  @unique
  passwordHash    String?
  fullName        String
  phone           String?
  role            UserRole
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Қарым-қатынастар
  ordersAsResponsible Order[]       @relation("OrderResponsible")
  tasksAssigned       ProductionTask[] @relation("TaskAssignee")
  statusHistory       OrderStatusHistory[]
  uploadedFiles       OrderFile[]
  notifications       Notification[]
  stockMovements      StockMovement[]
  messages            OrderMessage[]

  @@index([role])
  @@index([telegramId])
}

// ============== ТАПСЫРЫС ==============
model Order {
  id              String      @id @default(uuid())
  
  // Goszakup деректері
  goszakupId      String?     @unique  // тендердегі лот нөмірі
  tenderNumber    String                // тендер нөмірі
  contractNumber  String?               // келісімшарт нөмірі
  customerName    String                // тапсырыс беруші (мемлекеттік орган)
  customerBin     String?               // БСН
  
  // Өнім
  productName     String
  productDescription String?
  quantity        Int
  unit            String      @default("дана")
  totalAmount     Decimal     @db.Decimal(15, 2)
  currency        String      @default("KZT")
  
  // Мерзімдер
  contractDate    DateTime?
  deadline        DateTime              // жеткізу мерзімі
  startedAt       DateTime?
  completedAt     DateTime?
  
  // Жеткізу
  deliveryAddress String?
  deliveryContact String?

  // Көлік ақпараты (LOADING → LOGISTICS өткенде логист толтырады)
  transportProvider String?  // "Самосвал-Транс LLP" немесе жеке тасымалдаушы
  driverName        String?  // "Иванов Иван Иванович"
  driverPhone       String?  // "+7 700 123 4567"
  vehicleType       String?  // "Газель", "Камаз", т.б.
  vehiclePlate      String?  // "123ABC01"
  departedAt        DateTime?
  expectedArrival   DateTime?

  // Күй
  status          OrderStatus @default(NEW_TENDER)
  priority        Int         @default(0)  // 0-қалыпты, 1-жоғары, 2-шұғыл

  // Орындау түрі — Директор CONFIRMATION-да таңдайды
  fulfillmentType FulfillmentType @default(PRODUCTION)

  // Жауапты адам (ағымдағы кезеңде)
  responsibleId   String?
  responsible     User?       @relation("OrderResponsible", fields: [responsibleId], references: [id])

  notes           String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Қарым-қатынастар
  statusHistory   OrderStatusHistory[]
  productionTasks ProductionTask[]
  files           OrderFile[]
  notifications   Notification[]
  stockMovements  StockMovement[]
  messages        OrderMessage[]

  // STOCK fulfillment: қандай склад бірлігінен қанша алынатыны
  // (директор STORAGE-ке жібергенде толтырылады, LOADING → LOGISTICS-те шегеріледі)
  stockItemId     String?
  stockItem       StockItem?  @relation(fields: [stockItemId], references: [id], onDelete: SetNull)
  stockQuantity   Decimal?    @db.Decimal(12, 3)
  stockDeductedAt DateTime?   // қалдық шегерілген сәт (қайта шегеруден қорғау)

  @@index([status])
  @@index([deadline])
  @@index([goszakupId])
  @@index([stockItemId])
}

// ============== ТАПСЫРЫС МӘРТЕБЕСІНІҢ ТАРИХЫ ==============
model OrderStatusHistory {
  id          String      @id @default(uuid())
  orderId     String
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  fromStatus  OrderStatus?
  toStatus    OrderStatus
  
  changedById String
  changedBy   User        @relation(fields: [changedById], references: [id])
  
  comment     String?
  createdAt   DateTime    @default(now())

  @@index([orderId])
  @@index([createdAt])
}

// ============== ӨНДІРІС ТАПСЫРМАЛАРЫ ==============
// Өндіріс бастығы тапсырысты ұсақ тапсырмаларға бөліп, цех мамандарына таратады
model ProductionTask {
  id          String     @id @default(uuid())
  orderId     String
  order       Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  title       String
  description String?
  
  assigneeId  String?
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  
  status      TaskStatus @default(PENDING)
  
  startedAt   DateTime?
  completedAt DateTime?
  deadline    DateTime?
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([orderId])
  @@index([assigneeId])
  @@index([status])
}

// ============== ФАЙЛДАР (фото, PDF) ==============
enum FileType {
  CONTRACT       // келісімшарт
  TECHNICAL_SPEC // техникалық тапсырма
  PRODUCTION_PHOTO // өндіріс фотосы
  PACKAGING_PHOTO  // қаптау фотосы
  LOADING_PHOTO    // тиеу фотосы
  DELIVERY_PHOTO   // жеткізу фотосы
  INVOICE          // шот-фактура
  OTHER
}

model OrderFile {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  fileName    String
  fileType    FileType
  filePath    String   // серверде сақталған жол
  mimeType    String
  sizeBytes   Int

  uploadedById String
  uploadedBy   User    @relation(fields: [uploadedById], references: [id])

  createdAt   DateTime @default(now())

  messages    OrderMessage[] // осы файлға қоса жіберілген хабарламалар

  @@index([orderId])
}

// ============== КЕЗЕҢАРАЛЫҚ ХАБАРЛАМАЛАР ==============
// Әр кезеңде жауаптылар тапсырыс бойынша бір-біріне жазбаша
// хабарлама + файл жібере алады (қате, түсіндіру, растау).
model OrderMessage {
  id          String       @id @default(uuid())
  orderId     String
  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  authorId    String
  author      User         @relation(fields: [authorId], references: [id])

  text        String       @db.Text

  // Қажет болса — бар OrderFile-ды тіркейміз (қайта жүктемей).
  fileId      String?
  file        OrderFile?   @relation(fields: [fileId], references: [id], onDelete: SetNull)

  // Бұл хабарлама қай кезеңде жіберілді (тарих үшін).
  stage       OrderStatus

  createdAt   DateTime     @default(now())

  @@index([orderId, createdAt])
}

// ============== ХАБАРЛАМАЛАР (Telegram) ==============
enum NotificationType {
  STATUS_CHANGE   // статус өзгерді
  TASK_ASSIGNED   // тапсырма берілді
  DEADLINE_WARNING // мерзім жақындады
  DELAY           // кешіктіру
  COMPLETED       // аяқталды
  NEW_ORDER       // жаңа тапсырыс (Goszakup-тан)
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  orderId     String?
  order       Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)

  type        NotificationType
  title       String
  message     String

  isSent      Boolean          @default(false)
  isRead      Boolean          @default(false)
  sentAt      DateTime?

  createdAt   DateTime         @default(now())

  @@index([userId, isRead])
  @@index([isSent])
}

// ============== СКЛАД (ИНВЕНТАРЬ) ==============

// Склад қозғалысының түрі — әр өзгеріс журналға жазылады.
enum StockMovementType {
  IN       // приход (поступление, импорт)
  OUT      // расход (тапсырыс жөнелтілді)
  ADJUST   // түзету (инвентаризация, қолмен)
}

// Склад бірлігі — әр сақталатын тауар/шикізат/қаптама.
// quantity әрдайым StockMovement қозғалыстарының қосындысы — derived, бірақ
// тез оқу үшін осы өрісте сақталады. Барлық өзгерістер транзакциямен жүреді.
model StockItem {
  id           String   @id @default(uuid())
  sku          String?  @unique             // өнім коды (қажет болса)
  name         String
  category     String?                       // "тауар" / "шикізат" / "қаптама" т.б.
  unit         String   @default("дана")

  // Ағымдағы қалдық. Әр StockMovement осыны атомдық түрде жаңартады.
  quantity     Decimal  @default(0) @db.Decimal(12, 3)
  // Төмен қалдық сигналы — UI бұл шектен төмен бірліктерді қызыл етіп көрсетеді.
  minQuantity  Decimal? @db.Decimal(12, 3)

  location     String?                       // склад сектор: "А1-3"
  notes        String?

  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  movements    StockMovement[]
  orders       Order[]                       // тапсырыстарға байланған бірлік

  @@index([name])
  @@index([category])
  @@index([isActive])
}

// Әр қозғалыс — өзгермейтін журнал жазбасы (audit trail).
// `quantity` әрдайым оң — белгіні `type` шешеді (IN +, OUT −, ADJUST = жаңа мәнге орнату).
model StockMovement {
  id            String            @id @default(uuid())
  stockItemId   String
  stockItem     StockItem         @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  type          StockMovementType
  quantity      Decimal           @db.Decimal(12, 3)   // абсолюттік мән
  balanceAfter  Decimal           @db.Decimal(12, 3)   // қозғалыстан кейінгі қалдық — audit

  // Қозғалыс белгілі тапсырысқа байланса (мысалы, LOADING-те автоматты шегеру)
  orderId       String?
  order         Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)

  comment       String?
  createdById   String?
  createdBy     User?             @relation(fields: [createdById], references: [id])
  createdAt     DateTime          @default(now())

  @@index([stockItemId, createdAt])
  @@index([orderId])
  @@index([type])
}
